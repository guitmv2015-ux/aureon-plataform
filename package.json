{
  "name": "aureon-partners-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma institutional Aureon Partners — Next.js 15 + Payload CMS + Prisma + Stripe",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "npm run payload:generate-importmap && next build",
    "start": "prisma db push && next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "prepare": "husky",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed/index.ts",
    "db:studio": "prisma studio",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "payload:generate-types": "payload generate:types",
    "payload:generate-importmap": "node -e \"fs.mkdirSync('src/app/(payload)/admin', { recursive: true }); fs.writeFileSync('src/app/(payload)/admin/importMap.js', 'export const importMap = {};')\" && payload generate:importmap",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "next": "15.1.11",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "payload": "3.16.0",
    "@payloadcms/next": "3.16.0",
    "@payloadcms/db-postgres": "3.16.0",
    "@payloadcms/richtext-lexical": "3.16.0",
    "@payloadcms/storage-uploadthing": "3.16.0",
    "@payloadcms/plugin-seo": "3.16.0",
    "@payloadcms/plugin-form-builder": "3.16.0",
    "graphql": "16.9.0",
    "@prisma/client": "5.22.0",
    "prisma": "5.22.0",
    "next-auth": "5.0.0-beta.25",
    "@auth/prisma-adapter": "2.7.4",
    "bcryptjs": "2.4.3",
    "stripe": "17.5.0",
    "resend": "4.0.1",
    "@react-email/components": "0.0.31",
    "@react-email/render": "1.0.3",
    "uploadthing": "7.4.4",
    "@uploadthing/react": "7.1.5",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-tooltip": "1.1.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "2.6.0",
    "tailwindcss-animate": "1.0.7",
    "framer-motion": "11.15.0",
    "lucide-react": "0.469.0",
    "recharts": "2.15.0",
    "sonner": "1.7.1",
    "zod": "3.24.1",
    "react-hook-form": "7.54.2",
    "@hookform/resolvers": "3.10.0",
    "date-fns": "4.1.0",
    "nanoid": "5.0.9",
    "next-themes": "0.4.4"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "@types/node": "22.10.5",
    "@types/react": "19.0.4",
    "@types/react-dom": "19.0.2",
    "@types/bcryptjs": "2.4.6",
    "tailwindcss": "3.4.17",
    "@tailwindcss/typography": "0.5.15",
    "postcss": "8.4.49",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "15.1.6",
    "@typescript-eslint/eslint-plugin": "8.19.1",
    "@typescript-eslint/parser": "8.19.1",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "0.6.9",
    "husky": "9.1.7",
    "lint-staged": "15.3.0",
    "tsx": "4.19.2",
    "cross-env": "7.0.3",
    "@next/bundle-analyzer": "15.1.6"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed/index.ts"
  }
}