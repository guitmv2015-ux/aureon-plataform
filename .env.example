# ──────────────────────────────────────────────────────────────────────────
# AUREON PARTNERS PLATFORM — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# Nunca faça commit do arquivo .env preenchido.
# ──────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Banco de dados (Postgres) — usado por Prisma (schema "public") e
# pelo Payload (schema "payload"), no MESMO banco, em schemas separados.
DATABASE_URL="postgresql://user:password@localhost:5432/aureon?schema=public"

# Payload CMS
PAYLOAD_SECRET="troque-por-uma-string-aleatoria-de-32-bytes"

# Auth.js (NextAuth v5)
AUTH_SECRET="troque-por-uma-string-aleatoria-de-32-bytes"
AUTH_TRUST_HOST="true"

# OAuth opcional (Google) — deixe vazio para desabilitar o provider
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend (e-mails transacionais e de marketing)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Aureon Partners <contato@aureonpartners.pro>"
SALES_NOTIFICATION_EMAIL="comercial@aureonpartners.pro"

# Stripe (pagamentos e assinaturas)
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_ID_ESSENTIAL="price_xxxxxxxxxxxxx"
STRIPE_PRICE_ID_PRIVATE="price_xxxxxxxxxxxxx"

# UploadThing (upload de documentos na área do cliente)
UPLOADTHING_TOKEN="eyJhbGciOiJIUzI1NiJ9.xxxxxxxxxxxxxxxxxxxxx"

# Integração de CRM (adapter plugável — ver src/lib/crm)
CRM_PROVIDER="hubspot" # "hubspot" | "none"
HUBSPOT_PRIVATE_APP_TOKEN=""

# Cron / jobs internos (proteção do endpoint de sincronização)
CRON_SECRET="troque-por-uma-string-aleatoria"

# Analytics (opcional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_VERCEL_ANALYTICS="true"
